<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="8dp"
    android:layout_marginRight="8dp"
    android:layout_marginLeft="8dp"
    app:cardCornerRadius="15dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="10dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">
        <ImageView
            android:id="@+id/item_image"
            android:layout_width="130dp"
            android:layout_height="150dp"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="5dp"/>
        <TextView
            android:background="@drawable/gradient_label"
            android:textColor="@color/white"
            android:padding="8dp"
            android:id="@+id/label_item_name"
            android:layout_marginBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name:"
            android:layout_marginLeft="5dp"
            android:textSize="15sp"
            android:layout_toRightOf="@+id/item_image"/>
        <TextView
            android:id="@+id/text_item_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name:"
            android:textColor="@color/cardview_dark_background"
            android:padding="5dp"
            android:layout_marginLeft="5dp"
            android:textSize="10sp"
            android:layout_alignBaseline="@+id/label_item_name"
            android:layout_toRightOf="@+id/label_item_name"/>
        <TextView
            android:background="@drawable/gradient_label"
            android:textColor="@color/white"
            android:padding="8dp"
            android:id="@+id/label_item_category"
            android:layout_marginBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Category:"
            android:layout_marginLeft="5dp"
            android:layout_below="@+id/label_item_name"
            android:textSize="15sp"
            android:layout_toRightOf="@+id/item_image" />
        <TextView
            android:id="@+id/text_item_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name:"
            android:padding="5dp"
            android:layout_marginLeft="5dp"
            android:textSize="10sp"
            android:textColor="@color/cardview_dark_background"
            android:layout_below="@+id/label_item_name"
            android:layout_alignBaseline="@+id/label_item_category"
            android:layout_toRightOf="@+id/label_item_category"/>
        <TextView
            android:background="@drawable/gradient_label"
            android:textColor="@color/white"
            android:padding="8dp"
            android:id="@+id/label_item_used_status"
            android:layout_marginBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usage Status:"
            android:layout_marginLeft="5dp"
            android:layout_below="@+id/label_item_category"
            android:textSize="15sp"
            android:layout_toRightOf="@+id/item_image"/>
        <TextView
            android:id="@+id/text_item_used_status"
            android:textColor="@color/cardview_dark_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name:"
            android:padding="5dp"
            android:layout_marginLeft="5dp"
            android:textSize="10sp"
            android:layout_below="@+id/label_item_category"
            android:layout_alignBaseline="@+id/label_item_used_status"
            android:layout_toRightOf="@+id/label_item_used_status"/>
        <TextView
            android:background="@drawable/gradient_label"
            android:textColor="@color/white"
            android:padding="8dp"
            android:id="@+id/label_item_redeemed_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Redeem Status:"
            android:layout_marginLeft="5dp"
            android:layout_below="@+id/label_item_used_status"
            android:textSize="15sp"
            android:layout_toRightOf="@+id/item_image"/>
        <TextView
            android:id="@+id/text_item_redeemed_status"
            android:textColor="@color/cardview_dark_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item Name:"
            android:textStyle="bold"
            android:padding="5dp"
            android:layout_marginLeft="5dp"
            android:textSize="10sp"
            android:layout_below="@+id/label_item_used_status"
            android:layout_alignBaseline="@+id/label_item_redeemed_status"
            android:layout_toRightOf="@+id/label_item_redeemed_status"/>


    </RelativeLayout>
</androidx.cardview.widget.CardView>